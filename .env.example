# =============================
# Required connection settings
# =============================

# PostgreSQL connection URL containing your bans table.
# Example: postgres://username:password@host:port/db_name
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# SQLite URL for newsletter metadata (registered channels + sent message map).
# Example path relative to current working directory.
NEWSLETTER_DATABASE_URL=sqlite://newsletter.db?mode=rwc

# Discord bot token.
DISCORD_TOKEN=replace_with_discord_bot_token

# Which events are enabled for processing.
# Accepted values:
# - Notification channels: ban_added, ban_edited
# - Internal event names:  added, edited
# You can mix both forms and separate with comma/space/newline.
EVENT_NAMES=ban_added,ban_edited

# =============================
# Optional files
# =============================

# Optional path to embed XML template file.
# If omitted, built-in localized template is used.
# EMBED_FILE=./embed.xml

# Optional path to i18n json/json5/jsonc file.
# If omitted, built-in English translations are used.
# I18_FILE=./i18n.json5

# =============================
# Ban table integration mapping
# =============================

# Table that stores bans. Supports schema-qualified names.
BANS_TABLE=public.bans

# Column mappings used to load a single ban row for newsletter embeds.
BANS_COL_ID=id
BANS_COL_INTRUDER=intruder
BANS_COL_ADMIN=admin
BANS_COL_TYPE=type
BANS_COL_ROUND_ID=round_id
BANS_COL_SERVER=server
BANS_COL_DURATION_END=duration_end
BANS_COL_REASON=reason

# =============================
# Schema creation prompt control
# =============================

# If true/1, skip interactive [y/n] prompt and auto-create missing DB objects.
# Recommended for containers and CI.
AUTO_CONFIRM_SCHEMA_CHANGES=false

# =============================
# Detailed alternate table example
# =============================
# BANS_TABLE=public.ban_records
# BANS_COL_ID=ban_id
# BANS_COL_INTRUDER=target_ckey
# BANS_COL_ADMIN=banned_by
# BANS_COL_TYPE=ban_type
# BANS_COL_ROUND_ID=round_ref
# BANS_COL_SERVER=server_name
# BANS_COL_DURATION_END=expires_at
# BANS_COL_REASON=ban_reason
