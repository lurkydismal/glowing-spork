POSTGRES_USER='postgres'
POSTGRES_PASSWORD='postgres'
POSTGRES_DB='appdb'
DB_HOST='localhost'
DB_PORT=5432
DATABASE_URL="postgres://$POSTGRES_USER:$POSTGRES_PASSWORD@$DB_HOST:$DB_PORT/$POSTGRES_DB"

EVENT_NAMES="bans_inserted"
DISCORD_TOKEN="token"
# Use a SQLite in memory database so no setup needed.
NEWSLETTER_DATABASE_URL="sqlite::memory:"
